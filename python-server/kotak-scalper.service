[Unit]
Description=AKATSUKI Options Scalping Terminal
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/kotak-scalper
Environment=DATABASE_URL=postgresql://user:pass@localhost:5432/akatsuki
Environment=SESSION_SECRET=your-secret-key-here
ExecStart=/home/ubuntu/kotak-scalper/venv/bin/uvicorn main:app --host 0.0.0.0 --port 5000 --loop uvloop
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
